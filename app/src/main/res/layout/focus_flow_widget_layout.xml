<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_gradient_bg"
    android:padding="14dp"
    android:clipToPadding="false">

    <!-- Cat Mascot (right side, semi-transparent) -->
    <ImageView
        android:id="@+id/widget_mascot"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:src="@drawable/cat_mascot_full_view_nobg"
        android:scaleType="fitEnd"
        android:alpha="0.5" />

    <!-- Content on the left -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/widget_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FocusFlow ⚡"
                android:textColor="#C5CAE9"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_mode_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON TRACK ✅"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:background="#3D5AFE"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- GOAL PROGRESS SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯"
                android:textSize="13sp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/widget_main_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0m / 150m"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginBottom="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#7C4DFF"
            android:progressBackgroundTint="#37474F" />

        <!-- SHIFT VS YESTERDAY SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="13sp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No data yet"
                android:textColor="#B0BEC5"
                android:textSize="11sp"
                android:ellipsize="end"
                android:singleLine="true" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_shift_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#00BCD4"
            android:progressBackgroundTint="#37474F" />

    </LinearLayout>

</RelativeLayout>
